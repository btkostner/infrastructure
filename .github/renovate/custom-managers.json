{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Process annotated dependencies",
      "managerFilePatterns": ["/.env$/", "/.sh$/", "/.*y[a]?ml$/"],
      "matchStrings": [
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( extractVersion=(?<extractVersion>\\S+))?\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Process annotated GitHub URLs in kustomization files",
      "managerFilePatterns": ["/kustomization.yaml/"],
      "matchStrings": [
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+?)( extractVersion=(?<extractVersion>\\S+))?\\n\\s+- https://raw.githubusercontent.com/[^/]*/[^/]*/(?<currentValue>[^/]+)/",
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+?)( extractVersion=(?<extractVersion>\\S+))?\\n\\s+- https://github.com/[^/]*/[^/]*/releases/download/(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-tags{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Process OCI dependencies",
      "managerFilePatterns": ["/.*y[a]?ml$/"],
      "matchStrings": ["oci://(?<depName>[^:]+):(?<currentValue>\\S+)"],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Docker image tags",
      "managerFilePatterns": ["/.*y[a]?ml$/"],
      "matchStrings": ["image: (?<depName>.*?):(?<currentValue>.*?)"],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Github release downloads",
      "managerFilePatterns": ["/kustomization.yaml/"],
      "matchStrings": [
        "https://github.com/(?<depName>.*/.*?)/releases/download/(?<currentValue>.*?)/"
      ],
      "datasourceTemplate": "github-releases"
    }
  ]
}
